{
  "name": "@foundrynorth/core",
  "version": "1.0.4",
  "description": "Shared platform utilities for Foundry North applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./resilience": {
      "import": "./dist/resilience/index.js",
      "types": "./dist/resilience/index.d.ts"
    },
    "./observability": {
      "import": "./dist/observability/index.js",
      "types": "./dist/observability/index.d.ts"
    },
    "./events": {
      "import": "./dist/events/index.js",
      "types": "./dist/events/index.d.ts"
    },
    "./env": {
      "import": "./dist/env/index.js",
      "types": "./dist/env/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./text": {
      "import": "./dist/text/index.js",
      "types": "./dist/text/index.d.ts"
    },
    "./cache": {
      "import": "./dist/cache/index.js",
      "types": "./dist/cache/index.d.ts"
    },
    "./time": {
      "import": "./dist/time/index.js",
      "types": "./dist/time/index.d.ts"
    },
    "./dataforseo": {
      "import": "./dist/dataforseo/index.js",
      "types": "./dist/dataforseo/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "npm run build && npm test && npm run pack:dry-run",
    "prepublishOnly": "npm run release:check"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
